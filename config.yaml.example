providers:
  - name: deepseek
    type: deepseek
    enabled: true
    api_key: ""
    api_base: ""  # leave empty for default (https://api.deepseek.com)
    timeout: 30s  # optional timeout for API connection and time-to-first-byte (e.g., 30s, 1m)
    models:
      - name: deepseek-chat
        max_context_tokens: 65536  # optional; overrides global.max_context_tokens
        input_price: 0.27   # USD per 1M input tokens
        output_price: 1.10  # USD per 1M output tokens
      - name: deepseek-reasoner
        input_price: 0.55
        output_price: 2.19

  # Uncomment to add OpenAI support:
  # - name: openai
  #   type: openai
  #   enabled: true
  #   api_key: ""
  #   api_base: ""  # leave empty for default (https://api.openai.com/v1)
  #   models:
  #     - name: gpt-4o
  #       input_price: 2.50
  #       output_price: 10.00
  #     - name: gpt-4o-mini
  #       input_price: 0.15
  #       output_price: 0.60

  # Anthropic uses its native Messages API, not an OpenAI-compatible proxy.
  # Obtain an API key from the Anthropic Console. Anthropic temperatures must
  # be between 0 and 1, so each model needs an override when global.temperature
  # is greater than 1.
  # - name: anthropic
  #   type: anthropic
  #   enabled: true
  #   api_key: ""
  #   api_base: ""  # leave empty for default (https://api.anthropic.com)
  #   timeout: 10m
  #   models:
  #     - name: claude-sonnet-4-6
  #       temperature: 0.7

  # Uncomment to add xAI (Grok) support:
  # - name: xai
  #   type: xai
  #   enabled: true
  #   api_key: ""
  #   api_base: ""  # leave empty for default (https://api.x.ai/v1)
  #   models:
  #     - name: grok-2-latest
  #       input_price: 2.00
  #       output_price: 10.00
  #     - name: grok-beta
  #       input_price: 5.00
  #       output_price: 15.00

  # Uncomment to add Perplexity support:
  # - name: perplexity
  #   type: perplexity
  #   enabled: true
  #   api_key: ""
  #   api_base: ""  # leave empty for default (https://api.perplexity.ai)
  #   models:
  #     - name: llama-3.1-sonar-large-128k-online
  #       input_price: 1.00
  #       output_price: 1.00
  #     - name: llama-3.1-sonar-small-128k-online
  #       input_price: 0.20
  #       output_price: 0.20

  # Uncomment to add Ollama (Local) support:
  # - name: ollama
  #   type: ollama
  #   enabled: true
  #   api_key: "ollama" # optional for local, but required by some parsers
  #   api_base: ""  # leave empty for default (http://localhost:11434/v1)
  #   models:
  #     - name: llama3.2

  # Uncomment to add Groq support:
  # - name: groq
  #   type: groq
  #   enabled: true
  #   api_key: ""
  #   api_base: ""  # leave empty for default (https://api.groq.com/openai/v1)
  #   models:
  #     - name: llama-3.3-70b-versatile

  # Uncomment to add Together AI support:
  # - name: together
  #   type: together
  #   enabled: true
  #   api_key: ""
  #   api_base: ""  # leave empty for default (https://api.together.xyz/v1)
  #   models:
  #     - name: meta-llama/Llama-3.3-70B-Instruct-Turbo

  # Uncomment to add Mistral AI support:
  # - name: mistral
  #   type: mistral
  #   enabled: true
  #   api_key: ""
  #   api_base: ""  # leave empty for default (https://api.mistral.ai/v1)
  #   models:
  #     - name: mistral-large-latest

  # - name: azure
  #   type: azure
  #   enabled: false
  #   api_key: "your_azure_openai_key"
  #   api_base: "your-resource-name"  # e.g., "my-company-ai"
  #   api_version: "2024-02-15-preview"
  #   models:
  #     - name: my-gpt-4-deployment  # For Azure, this is the Deployment ID

  # - name: cloudflare
  #   type: cloudflare
  #   enabled: false
  #   api_key: "your_cloudflare_api_token"
  #   cloudflare_account_id: "your_cloudflare_account_id"
  #   models:
  #     - name: @cf/meta/llama-3-8b-instruct

  # Uncomment to add Amazon Bedrock support:
  # - name: bedrock
  #   type: bedrock
  #   enabled: true
  #   aws_region: "us-east-1" # required if not set in environment
  #   aws_access_key: "AKIA..." # optional if using IAM roles
  #   aws_secret_key: "..." # optional if using IAM roles
  #   models:
  #     - name: anthropic.claude-3-7-sonnet-20250219-v1:0

  - name: google
    type: google
    enabled: true
    api_key: "YOUR_GEMINI_API_KEY_HERE"
    models:
      - name: gemini-2.5-flash
        input_price: 0.075
        output_price: 0.30
        temperature: 0.4
      - name: gemini-2.5-pro
        input_price: 1.25
        output_price: 5.00
        temperature: 0.7

  # Uncomment to add a Custom (OpenAI-compatible) API:
  # - name: custom
  #   type: custom
  #   enabled: true
  #   api_key: "your_custom_api_key"
  #   api_base: "https://your-custom-endpoint.com/v1"
  #   models:
  #     - name: your-custom-model

database:
  backend: "sqlite" # "sqlite" or "mysql"
  
  sqlite:
    path: "omni.db"
    
  # mysql:
  #   host: "127.0.0.1"
  #   port: 3306
  #   user: "omni_user"
  #   password: "supersecretpassword"
  #   db_name: "omni"

  # postgres:
  #   host: "aws-0-us-east-1.pooler.supabase.com"
  #   port: 6543
  #   user: "postgres.yourprojectref"
  #   password: "your_password"
  #   db_name: "postgres"
  #   sslmode: "require"

global:
  initial_prompt: >-
    You are a helpful assistant. Use Telegram-compatible Markdown when
    formatting improves readability. Do not use LaTeX formatting.
  temperature: 1.3
  max_reply_tokens: 2048
  max_context_tokens: 8192
  history_size: 4
  sender_context: "groups"
  session_timeout: "15m"
  max_sessions_displayed: 10
  
  # (Optional) A dedicated fast model used exclusively to generate background titles.
  # If left blank, it will fallback to generating titles using the current active model.
  # title_model: "gemini-2.5-flash"

telegram:
  bot_token: ""
  allowed_user_ids: []
  admin_user_ids: []
  # Use numeric chat IDs (usually negative, such as -1001234567890).
  allowed_group_ids: []
